---
name: parallel-join
version: 1
schema: omhflow/v1
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Parallel Join Gate

```yaml workflow
sequence:
  - node:
      id: start
      type: script
      script:
        language: js
        file: scripts/start.js
      writes:
        - /parallel
  - parallel:
      - node:
          id: leftProbe
          type: script
          script:
            language: js
            file: scripts/left-probe.js
          reads:
            - /parallel
      - node:
          id: rightProbe
          type: script
          script:
            language: js
            file: scripts/right-probe.js
          reads:
            - /parallel
    join:
      id: collect
      type: script
      script:
        language: js
        file: scripts/collect.js
      writes:
        - /parallel
  - node:
      id: finish
      type: script
      script:
        language: js
        file: scripts/finish.js
      reads:
        - /parallel
```
