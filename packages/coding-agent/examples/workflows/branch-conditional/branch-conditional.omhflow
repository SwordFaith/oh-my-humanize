---
name: branch-conditional
version: 1
schema: omhflow/v1
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Branch Conditional Gate

```yaml workflow
nodes:
  route:
    type: script
    script:
      language: js
      file: scripts/route.js
    writes:
      - /branch
  fastPath:
    type: script
    script:
      language: js
      file: scripts/fast-path.js
    reads:
      - /branch
    writes:
      - /branch
  safePath:
    type: script
    script:
      language: js
      file: scripts/safe-path.js
    reads:
      - /branch
    writes:
      - /branch
  finish:
    type: script
    script:
      language: js
      file: scripts/finish.js
    reads:
      - /branch
edges:
  - from: route
    to: fastPath
    when: outputs.route.route == "fast"
  - from: route
    to: safePath
    when: outputs.route.route == "safe"
  - from: fastPath
    to: finish
  - from: safePath
    to: finish
```
