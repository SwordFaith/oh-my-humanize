---
name: loop-until-done
version: 1
schema: omhflow/v1
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Loop Until Done Gate

```yaml workflow
nodes:
  iterate:
    type: script
    script:
      language: js
      file: scripts/iterate.js
    writes:
      - /loop
  finish:
    type: script
    script:
      language: js
      file: scripts/finish.js
    reads:
      - /loop
edges:
  - from: iterate
    to: iterate
    when: outputs.iterate.continue == true
  - from: iterate
    to: finish
    when: outputs.iterate.continue == false
```
